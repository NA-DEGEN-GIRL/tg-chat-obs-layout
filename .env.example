# Telegram bot token from BotFather.
BOT_TOKEN=

# Target Telegram group/supergroup id. Usually starts with -100.
CHAT_ID=

# Telegram user id allowed to run admin commands.
OWNER_ID=

# Main chat overlay server for OBS Browser Source.
WEB_HOST=127.0.0.1
WEB_PORT=9292
FADE_AFTER_SEC=30
CHAT_FONT_SIZE=22

# STT. Leave API keys empty if you do not use STT.
STT_PROVIDER=openai
OPENAI_API_KEY=
GEMINI_API_KEY=
STT_MODEL_OPENAI=gpt-4o-mini-transcribe
STT_MODEL_GEMINI=gemini-3.1-flash-live-preview
STT_LANGUAGE=ko
STT_INPUT_DEVICE=

# Send STT result as: bot | user
# user mode uses a Telethon user session from TD_API_ID/TD_API_HASH/TD_PHONE.
STT_SEND_AS=bot
STT_AI_LABEL=0
STT_AI_LABEL_TEXT=aiSTT
STT_SEND_AS_USER_FALLBACK_BOT=1

# Optional local web sender. When enabled, /api/send can send messages as the
# Telegram user session to CHAT_ID and the active /here_on thread.
TELEGRAM_USER_SEND_ENABLED=0
TELEGRAM_USER_SEND_PANEL=0
TELEGRAM_USER_SEND_FALLBACK_BOT=0
TELEGRAM_USER_SEND_MAX_CHARS=1000
TELEGRAM_USER_SEND_MAX_PHOTO_MB=8
TELEGRAM_USER_SEND_MAX_MEDIA_MB=50

# Telegram user API values from https://my.telegram.org/apps.
# Required for Telethon videochat watcher, STT_SEND_AS=user, or web sender.
TD_API_ID=
TD_API_HASH=
TD_PHONE=

# Videochat/live stream link. You can also pass --link at runtime.
TD_VIDEOCHAT_LINK=

# Videochat character overlay server.
VIDEOCHAT_WEB_HOST=127.0.0.1
VIDEOCHAT_WEB_PORT=9393
VIDEOCHAT_CHAT_WS_URL=ws://127.0.0.1:9292/ws

# Host identity for crown and Lv. 99.
# Prefer VIDEOCHAT_HOST_USER_ID or VIDEOCHAT_HOST_USERNAME over name matching.
VIDEOCHAT_HOST_USER_ID=
VIDEOCHAT_HOST_USERNAME=
VIDEOCHAT_HOST_NAME=Host
VIDEOCHAT_HOST_AVATAR_FILE=

# Optional chat id used for collecting level/profile records.
# 0 disables separate level-chat collection.
VIDEOCHAT_LEVEL_CHAT_ID=0
VIDEOCHAT_LEVEL_SYSTEM_ENABLED=1
LEVEL_REASONS_FILE=
LEVEL_UP_TEMPLATE={name}(@{username}) 레벨 업! 현재 Lv. {level} - {reason}
LEVEL_DOWN_TEMPLATE={name}(@{username}) 레벨 다운. 현재 Lv. {level}
FORCE_LEVEL_UP_TEMPLATE=관리자가 {name}(@{username}) 레벨을 강제로 +{delta} 올렸습니다. 현재 Lv. {level}
FORCE_LEVEL_DOWN_TEMPLATE=관리자가 {name}(@{username}) 레벨을 강제로 {delta} 내렸습니다. 현재 Lv. {level}
VIDEOCHAT_FIRE_USER_COOLDOWN_SEC=3
VIDEOCHAT_FIRE_GLOBAL_COOLDOWN_SEC=1

VIDEOCHAT_WATCH_ENABLED=1
VIDEOCHAT_WATCH_INTERVAL=2
VIDEOCHAT_DOWNLOAD_PHOTOS=1
VIDEOCHAT_DEBUG_SPEECH=0

# Optional TDLib probe for real participant camera/screen stream research.
# The DLL itself is local-only and ignored by git.
TDLIB_JSON_DLL=vendor/tdlib/tdjson.dll
TDLIB_DATABASE_DIR=data/tdlib/videochat_probe
TDLIB_FILES_DIR=data/tdlib/videochat_probe_files

# Experimental: receive normal participant camera/screen frames through PyTgCalls.
# Use a separate receiver/sub-account session so the host account is not disturbed.
# /stream_watch can start this on demand even when autostart is disabled.
VIDEOCHAT_TGCALLS_PREVIEW_ENABLED=0
VIDEOCHAT_TGCALLS_AUTO_JOIN=1
VIDEOCHAT_FORCE_EXIT_ON_SHUTDOWN=1
VIDEOCHAT_DIAGNOSTICS_ENABLED=1
VIDEOCHAT_DIAG_INTERVAL_SEC=5
TGCALLS_SESSION=data/telethon/videochat_receiver
TGCALLS_PHONE=
TGCALLS_CHAT_IDS=
TGCALLS_MJPEG_FPS=30
TGCALLS_MJPEG_QUALITY=82
TGCALLS_MJPEG_WIDTH=1280
TGCALLS_MJPEG_HEIGHT=720
TGCALLS_MJPEG_KEEPALIVE_SEC=2.5
