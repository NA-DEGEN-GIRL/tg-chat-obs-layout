# 텔레그램 봇 토큰 (BotFather에서 발급)
BOT_TOKEN=여기에_봇_토큰_입력

# 방송할 채팅방 ID (슈퍼그룹은 -100 으로 시작)
CHAT_ID=-1001234567890

# 봇 소유자(본인) 텔레그램 유저 ID
OWNER_ID=123456789

# 오버레이 웹서버 바인드 주소/포트 (OBS 브라우저 소스용)
WEB_HOST=127.0.0.1
WEB_PORT=9292

# 메시지 N초 후 페이드아웃. -1 이면 페이드아웃 없음(계속 남김).
FADE_AFTER_SEC=30

# ─────────────────────────────────────────────
# STT (마이크 → 텍스트) 설정
# /tts_on 명령으로 시작, /tts_off 로 종료.
# 호스트 마이크 → 해당 프로바이더 STT → 봇이 그룹에 포스팅 + 오버레이에 표시
# ─────────────────────────────────────────────
STT_PROVIDER=openai
# openai | gemini

OPENAI_API_KEY=
GEMINI_API_KEY=

# OpenAI 트랜스크립션 모델. 기본은 최신 mini 트랜스크립션(가성비 최고).
# gpt-4o-transcribe (더 정확), gpt-realtime-1.5 (voice-agent, 비쌈) 으로 교체 가능.
STT_MODEL_OPENAI=gpt-4o-mini-transcribe

# Gemini Live 모델.
STT_MODEL_GEMINI=gemini-3.1-flash-live-preview

# 인식 언어 (ISO 639-1)
STT_LANGUAGE=ko

# 입력 마이크 지정. 비우면 OS 기본 마이크.
# 숫자(디바이스 인덱스) 또는 이름 일부(예: "Blue Yeti", "Shure"). 대소문자 무시.
STT_INPUT_DEVICE=

# 중요: 봇이 그룹 메시지를 읽으려면 BotFather에서
# /mybots -> (봇 선택) -> Bot Settings -> Group Privacy -> Turn off
# 로 프라이버시 모드를 꺼야 합니다. (또는 봇을 그룹 관리자로)
