# ─── 비밀 / 설정 ───
# 토큰, API 키 등 민감정보는 절대 커밋 금지. .env.example 만 커밋.
.env
.env.*
!.env.example

# ─── Python ───
__pycache__/
*.py[cod]
*$py.class
*.so
*.egg
*.egg-info/
build/
dist/
wheels/
*.whl
.Python
pip-log.txt
pip-delete-this-directory.txt
.pytest_cache/
.mypy_cache/
.ruff_cache/
.coverage
htmlcov/
.tox/

# ─── 가상환경 ───
.venv/
venv/
env/
ENV/
.python-version

# ─── uv ───
uv.lock
.uv-cache/

# ─── 런타임 데이터 ───
# 유저별 색상 매핑은 로컬 상태. 공유 불필요.
data/
logs/
*.log

# Local game ROMs / emulator saves. Keep copyrighted or personal files out of git.
*.gb
*.gbc
*.gba
*.nes
*.sfc
*.smc
*.rom
*.sav
*.state

# ─── IDE / 에디터 ───
.vscode/
.idea/
*.swp
*.swo
*~
.DS_Store
Thumbs.db

# ─── Claude Code ───
.claude/

# Local overlay debug captures
debug_videochat*.png
chrome-debug-profile*/

# Local TDLib binaries
vendor/tdlib/*.dll
vendor/tdlib/*.so
vendor/tdlib/*.so.*
vendor/tdlib/*.dylib
vendor/tdlib/build/
vendor/tdlib/td/
vendor/tdlib/pkg/

# Node / Electron
node_modules/
npm-debug.log*
tools/**/dist/
tools/**/out/

# ─── OS ───
desktop.ini
